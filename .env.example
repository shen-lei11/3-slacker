# Trio Hub environment variables
# Copy to .env for local dev, or set these in your Render service dashboard.

# Set to "production" on Render. Leave unset (or "development") locally.
FLASK_ENV=development

# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-string

# Optional. Defaults to a SQLite file inside DATA_DIR (or the app dir).
# DATABASE_URL=sqlite:////var/data/trio_hub.db

# Optional. Directory for the default SQLite file. On Render, point this at the
# mounted persistent disk (e.g. /var/data) so writes survive restarts/redeploys.
# DATA_DIR=/var/data

# Optional. Render injects PORT automatically; only override locally if needed.
# PORT=5000
